{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "gold", "color": "#c9a96e", "name": "Gold" },
        { "slug": "gold-light", "color": "#e8d5a3", "name": "Gold Light" },
        { "slug": "dark", "color": "#0a0a0a", "name": "Dark" },
        { "slug": "dark-2", "color": "#111111", "name": "Dark 2" },
        { "slug": "dark-3", "color": "#1a1a1a", "name": "Dark 3" },
        { "slug": "dark-4", "color": "#242424", "name": "Dark 4" },
        { "slug": "text-main", "color": "#f0ece4", "name": "Text" },
        { "slug": "text-muted", "color": "#888880", "name": "Text Muted" },
        { "slug": "white", "color": "#ffffff", "name": "White" },
        { "slug": "red", "color": "#c0392b", "name": "Red" },
        { "slug": "green", "color": "#25d366", "name": "Green (WhatsApp)" }
      ],
      "gradients": [],
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', serif",
          "slug": "playfair",
          "name": "Playfair Display"
        },
        {
          "fontFamily": "'Montserrat', sans-serif",
          "slug": "montserrat",
          "name": "Montserrat"
        },
        {
          "fontFamily": "'Bebas Neue', sans-serif",
          "slug": "bebas",
          "name": "Bebas Neue"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "10px", "name": "Extra Small" },
        { "slug": "sm", "size": "12px", "name": "Small" },
        { "slug": "base", "size": "14px", "name": "Base" },
        { "slug": "md", "size": "16px", "name": "Medium" },
        { "slug": "lg", "size": "20px", "name": "Large" },
        { "slug": "xl", "size": "28px", "name": "Extra Large" },
        { "slug": "2xl", "size": "38px", "name": "2X Large" },
        { "slug": "3xl", "size": "52px", "name": "3X Large" },
        { "slug": "4xl", "size": "68px", "name": "4X Large" }
      ],
      "defaultFontSizes": false
    },
    "spacing": {
      "units": ["px", "rem", "%", "vh"],
      "spacingSizes": [
        { "slug": "10", "size": "8px", "name": "XS" },
        { "slug": "20", "size": "16px", "name": "S" },
        { "slug": "30", "size": "24px", "name": "M" },
        { "slug": "40", "size": "40px", "name": "L" },
        { "slug": "50", "size": "60px", "name": "XL" },
        { "slug": "60", "size": "80px", "name": "2XL" },
        { "slug": "70", "size": "100px", "name": "3XL" },
        { "slug": "80", "size": "120px", "name": "4XL" }
      ]
    },
    "layout": {
      "contentSize": "1160px",
      "wideSize": "1400px"
    },
    "blocks": {}
  },
  "styles": {
    "color": {
      "background": "#0a0a0a",
      "text": "#f0ece4"
    },
    "typography": {
      "fontFamily": "'Montserrat', sans-serif",
      "fontSize": "14px",
      "lineHeight": "1.8"
    },
    "elements": {
      "heading": {
        "color": { "text": "#ffffff" },
        "typography": { "fontFamily": "'Playfair Display', serif", "fontWeight": "700" }
      },
      "h1": {
        "typography": { "fontSize": "clamp(48px, 7vw, 90px)", "fontWeight": "900", "lineHeight": "1" }
      },
      "h2": {
        "typography": { "fontFamily": "'Bebas Neue', sans-serif", "fontSize": "clamp(38px, 6vw, 68px)", "letterSpacing": "8px", "lineHeight": "1" }
      },
      "h3": {
        "typography": { "fontSize": "24px" }
      },
      "link": {
        "color": { "text": "#c9a96e" },
        ":hover": { "color": { "text": "#e8d5a3" } }
      },
      "button": {
        "color": { "background": "#c9a96e", "text": "#0a0a0a" },
        "typography": { "fontSize": "10px", "fontWeight": "700", "letterSpacing": "3px", "textTransform": "uppercase" },
        "border": { "radius": "50px" },
        ":hover": { "color": { "background": "#e8d5a3" } }
      }
    },
    "blocks": {
      "core/group": {
        "spacing": { "padding": { "left": "28px", "right": "28px" } }
      }
    }
  }
}
